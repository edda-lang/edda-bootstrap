function clone_audit_log(
    src: Vec_AuditEvent.Vec,
    retention: usize where retention > 0,
    allocator: Allocator,
) -> Vec_AuditEvent.Vec
    with {allocator, err: alloc.AllocError}
{
    let n: usize = Vec_AuditEvent.len(src)
    let data: [audit.AuditEvent] = Vec_AuditEvent._alloc_array(allocator, retention)?
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        data[i] = Vec_AuditEvent.at(src, i)
        i = i + 1
    }
    return Vec_AuditEvent.Vec {
        capacity: retention,
        len: n,
        data: data,
    }
}
