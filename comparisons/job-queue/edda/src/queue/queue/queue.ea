spec std.collections.vec.Vec(job.PendingEntry)
spec std.collections.vec.Vec(job.LeasedEntry)
spec std.collections.vec.Vec(job.DeadEntry)
spec std.collections.vec.Vec(job.CancelledEntry)
spec std.collections.vec.Vec(worker.WorkerEntry)
spec std.collections.vec.Vec(worker.WorkerView)
spec std.collections.vec.Vec(namespace.NamespaceState)
spec std.collections.vec.Vec(audit.AuditEvent)
spec std.collections.vec.Vec(metrics.NamespaceMetrics)
spec std.collections.vec.Vec(u64)
spec std.collections.vec.Vec(String)
spec std.core.option.Option(job.AcquiredJob)
spec std.core.option.Option(job.DeadEntry)
spec std.core.option.Option(job.CancelledEntry)










public type JobQueue {
    cfg: job.QueueConfig,
    pending: Vec_PendingEntry.Vec,
    leased: Vec_LeasedEntry.Vec,
    dead_letter: Vec_DeadEntry.Vec,
    cancelled: Vec_CancelledEntry.Vec,
    workers: Vec_WorkerEntry.Vec,
    namespaces: Vec_NamespaceState.Vec,
    audit_log: Vec_AuditEvent.Vec,
    next_id: u64 where next_id >= 1,
    next_seq: u64 where next_seq >= 1,
    next_event_id: u64 where next_event_id >= 1,
    last_seen_clock_nanos: i64 where last_seen_clock_nanos >= 0,
    jitter: retry.Jitter,
    strict_workers: bool,
    enqueued_total: u64,
    acquired_total: u64,
    completed_total: u64,
    failed_total: u64,
    lease_expired_total: u64,
    dead_lettered_total: u64,
    retry_scheduled_total: u64,
    cancelled_total: u64,
    promoted_total: u64,
}








public function new(
    cfg: job.QueueConfig,
    seed: u64 where seed != 0,
    allocator: Allocator,
) -> JobQueue
    with {allocator, err: alloc.AllocError}
{
    let pending_data: [job.PendingEntry] = Vec_PendingEntry._alloc_array(allocator, 0)?
    let leased_data: [job.LeasedEntry] = Vec_LeasedEntry._alloc_array(allocator, 0)?
    let dead_data: [job.DeadEntry] = Vec_DeadEntry._alloc_array(allocator, 0)?
    let cancelled_data: [job.CancelledEntry] = Vec_CancelledEntry._alloc_array(allocator, 0)?
    let workers_data: [worker.WorkerEntry] = Vec_WorkerEntry._alloc_array(allocator, 0)?
    let namespaces_data: [namespace.NamespaceState] = Vec_NamespaceState._alloc_array(allocator, 0)?
    let audit_data: [audit.AuditEvent] = Vec_AuditEvent._alloc_array(allocator, cfg.audit_retention)?
    return JobQueue {
        cfg: cfg,
        pending: Vec_PendingEntry.Vec { capacity: 0, len: 0, data: pending_data },
        leased: Vec_LeasedEntry.Vec { capacity: 0, len: 0, data: leased_data },
        dead_letter: Vec_DeadEntry.Vec { capacity: 0, len: 0, data: dead_data },
        cancelled: Vec_CancelledEntry.Vec { capacity: 0, len: 0, data: cancelled_data },
        workers: Vec_WorkerEntry.Vec { capacity: 0, len: 0, data: workers_data },
        namespaces: Vec_NamespaceState.Vec { capacity: 0, len: 0, data: namespaces_data },
        audit_log: Vec_AuditEvent.Vec { capacity: cfg.audit_retention, len: 0, data: audit_data },
        next_id: 1,
        next_seq: 1,
        next_event_id: 1,
        last_seen_clock_nanos: 0,
        jitter: retry.seed_jitter(seed),
        strict_workers: false,
        enqueued_total: 0,
        acquired_total: 0,
        completed_total: 0,
        failed_total: 0,
        lease_expired_total: 0,
        dead_lettered_total: 0,
        retry_scheduled_total: 0,
        cancelled_total: 0,
        promoted_total: 0,
    }
}






public function active_len(q: JobQueue) -> usize {
    return Vec_PendingEntry.len(q.pending)
}


public function leased_len(q: JobQueue) -> usize {
    return Vec_LeasedEntry.len(q.leased)
}


public function dead_letter_len(q: JobQueue) -> usize {
    return Vec_DeadEntry.len(q.dead_letter)
}


public function cancelled_len(q: JobQueue) -> usize {
    return Vec_CancelledEntry.len(q.cancelled)
}


public function audit_len(q: JobQueue) -> usize {
    return Vec_AuditEvent.len(q.audit_log)
}


public function dead_letter_at(
    q: JobQueue,
    i: usize where i < dead_letter_len(q),
) -> job.DeadEntry {
    return Vec_DeadEntry.at(q.dead_letter, i)
}


public function cancelled_at(
    q: JobQueue,
    i: usize where i < cancelled_len(q),
) -> job.CancelledEntry {
    return Vec_CancelledEntry.at(q.cancelled, i)
}


public function audit_at(
    q: JobQueue,
    i: usize where i < audit_len(q),
) -> audit.AuditEvent {
    return Vec_AuditEvent.at(q.audit_log, i)
}





spec std.core.option.Option(usize)




function empty_str_slice(allocator: Allocator) -> [String]
    with {allocator, err: alloc.AllocError}
{
    return Vec_String._alloc_array(allocator, 0)?
}



function find_namespace_index(namespaces: Vec_NamespaceState.Vec, name: String) -> Option_usize {
    let n: usize = Vec_NamespaceState.len(namespaces)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let ns: namespace.NamespaceState = Vec_NamespaceState.at(namespaces, i)
        if worker.string_equals(ns.name, name) {
            return Option_usize.some(value: i)
        }
        i = i + 1
    }
    return Option_usize.none
}


function find_worker_index(q: JobQueue, worker_id: u64) -> Option_usize {
    let n: usize = Vec_WorkerEntry.len(q.workers)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let w: worker.WorkerEntry = Vec_WorkerEntry.at(q.workers, i)
        if w.worker_id == worker_id {
            return Option_usize.some(value: i)
        }
        i = i + 1
    }
    return Option_usize.none
}


function find_leased_index(
    leased: Vec_LeasedEntry.Vec,
    worker_id: u64,
    job_id: u64,
) -> Option_usize {
    let n: usize = Vec_LeasedEntry.len(leased)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let entry: job.LeasedEntry = Vec_LeasedEntry.at(leased, i)
        if entry.worker_id == worker_id && entry.job.id == job_id {
            return Option_usize.some(value: i)
        }
        i = i + 1
    }
    return Option_usize.none
}


function find_leased_index_by_job(
    leased: Vec_LeasedEntry.Vec,
    job_id: u64,
) -> Option_usize {
    let n: usize = Vec_LeasedEntry.len(leased)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let entry: job.LeasedEntry = Vec_LeasedEntry.at(leased, i)
        if entry.job.id == job_id {
            return Option_usize.some(value: i)
        }
        i = i + 1
    }
    return Option_usize.none
}


function find_pending_index_by_job(
    pending: Vec_PendingEntry.Vec,
    job_id: u64,
) -> Option_usize {
    let n: usize = Vec_PendingEntry.len(pending)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let entry: job.PendingEntry = Vec_PendingEntry.at(pending, i)
        if entry.job.id == job_id {
            return Option_usize.some(value: i)
        }
        i = i + 1
    }
    return Option_usize.none
}








function ensure_namespace(
    q: mutable JobQueue,
    name: String,
    allocator: Allocator,
) -> usize
    with {allocator, err: alloc.AllocError}
{
    let existing: Option_usize = find_namespace_index(q.namespaces, name)
    return match existing {
        case .some(let idx) => idx
        case .none => {
            let fresh: namespace.NamespaceState = namespace.NamespaceState {
                name: name,
                active_capacity: q.cfg.active_capacity,
                dead_letter_capacity: q.cfg.dead_letter_capacity,
                enqueued_total: 0,
                acquired_total: 0,
                completed_total: 0,
                failed_total: 0,
                lease_expired_total: 0,
                dead_lettered_total: 0,
                retry_scheduled_total: 0,
                cancelled_total: 0,
                promoted_total: 0,
            }
            let new_idx: usize = Vec_NamespaceState.len(q.namespaces)
            Vec_NamespaceState.push(mutable q.namespaces, fresh, allocator)?
            new_idx
        }
    }
}


function count_namespace_active(q: JobQueue, name: String) -> usize {
    let n: usize = Vec_PendingEntry.len(q.pending)
    var count: usize = 0
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let e: job.PendingEntry = Vec_PendingEntry.at(q.pending, i)
        if worker.string_equals(e.namespace, name) {
            count = count + 1
        }
        i = i + 1
    }
    return count
}


function count_namespace_leased(q: JobQueue, name: String) -> usize {
    let n: usize = Vec_LeasedEntry.len(q.leased)
    var count: usize = 0
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let e: job.LeasedEntry = Vec_LeasedEntry.at(q.leased, i)
        if worker.string_equals(e.namespace, name) {
            count = count + 1
        }
        i = i + 1
    }
    return count
}













function audit_append(
    q: mutable JobQueue,
    kind: audit.AuditEventKind,
    at_nanos: i64 where at_nanos >= 0,
    job_id: u64,
    worker_id: u64,
    payload: String,
) -> () {
    let id: u64 = q.next_event_id
    q.next_event_id = q.next_event_id + 1
    let event: audit.AuditEvent = audit.AuditEvent {
        event_id: id,
        at_nanos: at_nanos,
        kind: kind,
        job_id: job_id,
        worker_id: worker_id,
        payload: payload,
    }
    if Vec_AuditEvent.len(q.audit_log) >= q.cfg.audit_retention {
        let _ = Vec_AuditEvent.remove(mutable q.audit_log, 0)
    }
    let pos: usize = q.audit_log.len
    q.audit_log.data[pos] = event
    q.audit_log.len = q.audit_log.len + 1
}








function deps_all_known(q: JobQueue, deps: [u64]) -> bool {
    let n: usize = deps.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if !is_known_id(q, deps[i]) {
            return false
        }
        i = i + 1
    }
    return true
}



function is_known_id(q: JobQueue, id: u64) -> bool {
    let in_pending: Option_usize = find_pending_index_by_job(q.pending, id)
    return match in_pending {
        case .some(_) => true
        case .none => {
            let in_leased: Option_usize = find_leased_index_by_job(q.leased, id)
            return match in_leased {
                case .some(_) => true
                case .none => {
                    if find_dead_index_by_job(q.dead_letter, id) {
                        return true
                    }
                    return find_cancelled_index_by_job(q.cancelled, id)
                }
            }
        }
    }
}


function find_dead_index_by_job(dead: Vec_DeadEntry.Vec, id: u64) -> bool {
    let n: usize = Vec_DeadEntry.len(dead)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let e: job.DeadEntry = Vec_DeadEntry.at(dead, i)
        if e.job.id == id { return true }
        i = i + 1
    }
    return false
}


function find_cancelled_index_by_job(cancelled: Vec_CancelledEntry.Vec, id: u64) -> bool {
    let n: usize = Vec_CancelledEntry.len(cancelled)
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let e: job.CancelledEntry = Vec_CancelledEntry.at(cancelled, i)
        if e.job.id == id { return true }
        i = i + 1
    }
    return false
}







function deps_same_namespace(q: JobQueue, deps: [u64], ns: String) -> bool {
    let n: usize = deps.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        if !dep_in_namespace(q, deps[i], ns) {
            return false
        }
        i = i + 1
    }
    return true
}



function dep_in_namespace(q: JobQueue, id: u64, ns: String) -> bool {
    let in_pending: Option_usize = find_pending_index_by_job(q.pending, id)
    return match in_pending {
        case .some(let idx) => worker.string_equals(Vec_PendingEntry.at(q.pending, idx).namespace, ns)
        case .none => {
            let in_leased: Option_usize = find_leased_index_by_job(q.leased, id)
            return match in_leased {
                case .some(let idx) => worker.string_equals(Vec_LeasedEntry.at(q.leased, idx).namespace, ns)
                case .none => dep_in_namespace_terminal(q, id, ns)
            }
        }
    }
}



function dep_in_namespace_terminal(q: JobQueue, id: u64, ns: String) -> bool {
    let dn: usize = Vec_DeadEntry.len(q.dead_letter)
    var i: usize = 0
    loop
        decreases dn - i
    {
        if i >= dn { break }
        let e: job.DeadEntry = Vec_DeadEntry.at(q.dead_letter, i)
        if e.job.id == id {
            return worker.string_equals(e.namespace, ns)
        }
        i = i + 1
    }
    let cn: usize = Vec_CancelledEntry.len(q.cancelled)
    var j: usize = 0
    loop
        decreases cn - j
    {
        if j >= cn { break }
        let ce: job.CancelledEntry = Vec_CancelledEntry.at(q.cancelled, j)
        if ce.job.id == id {
            return worker.string_equals(ce.namespace, ns)
        }
        j = j + 1
    }
    return false
}






function deps_eligible(q: JobQueue, deps: [u64]) -> bool {
    let n: usize = deps.len()
    var i: usize = 0
    loop
        decreases n - i
    {
        if i >= n { break }
        let dep_id: u64 = deps[i]
        let in_pending: Option_usize = find_pending_index_by_job(q.pending, dep_id)
        let pending_match: bool = match in_pending {
            case .some(_) => true
            case .none => false
        }
        if pending_match { return false }
        let in_leased: Option_usize = find_leased_index_by_job(q.leased, dep_id)
        let leased_match: bool = match in_leased {
            case .some(_) => true
            case .none => false
        }
        if leased_match { return false }
        i = i + 1
    }
    return true
}







public function enqueue(
    q: mutable JobQueue,
    payload: String,
    allocator: Allocator,
) -> u64
    with {allocator, err: queue_error.QueueError, err: alloc.AllocError}
{
    let no_deps: [u64] = Vec_u64._alloc_array(allocator, 0)?
    let no_caps: [String] = Vec_String._alloc_array(allocator, 0)?
    return enqueue_full2(
        mutable q,
        payload,
        5,
        0,
        "default",
        no_deps,
        no_caps,
        allocator,
    )?
}


public function enqueue_full(
    q: mutable JobQueue,
    payload: String,
    priority: u32,
    scheduled_at_nanos: i64 where scheduled_at_nanos >= 0,
    allocator: Allocator,
) -> u64
    with {allocator, err: queue_error.QueueError, err: alloc.AllocError}
{
    let no_deps: [u64] = Vec_u64._alloc_array(allocator, 0)?
    let no_caps: [String] = Vec_String._alloc_array(allocator, 0)?
    return enqueue_full2(
        mutable q,
        payload,
        priority,
        scheduled_at_nanos,
        "default",
        no_deps,
        no_caps,
        allocator,
    )?
}




public function enqueue_full2(
    q: mutable JobQueue,
    payload: String,
    priority: u32,
    scheduled_at_nanos: i64 where scheduled_at_nanos >= 0,
    ns: String,
    depends_on: [u64],
    required_capabilities: [String],
    allocator: Allocator,
) -> u64
    with {allocator, err: queue_error.QueueError, err: alloc.AllocError}
{
    if priority < 1 {
        raise queue_error.QueueError.invalid_priority
    }
    if priority > 10 {
        raise queue_error.QueueError.invalid_priority
    }
    if !deps_all_known(q, depends_on) {
        raise queue_error.QueueError.invalid_dependency
    }
    if !deps_same_namespace(q, depends_on, ns) {
        raise queue_error.QueueError.invalid_dependency
    }
    let ns_idx: usize = ensure_namespace(mutable q, ns, allocator)?
    let ns_state: namespace.NamespaceState = Vec_NamespaceState.at(q.namespaces, ns_idx)
    if count_namespace_active(q, ns) >= ns_state.active_capacity {
        raise queue_error.QueueError.queue_full
    }
    let id: u64 = q.next_id
    let seq: u64 = q.next_seq
    let entry: job.PendingEntry = job.PendingEntry {
        job: job.Job {
            id: id,
            payload: payload,
            attempt: 0,
            priority: priority,
        },
        namespace: ns,
        available_at_nanos: scheduled_at_nanos,
        scheduled_at_nanos: scheduled_at_nanos,
        seq: seq,
        depends_on: depends_on,
        required_capabilities: required_capabilities,
    }
    Vec_PendingEntry.push(mutable q.pending, entry, allocator)?
    q.next_id = q.next_id + 1
    q.next_seq = q.next_seq + 1
    q.enqueued_total = q.enqueued_total + 1
    bump_ns_enqueued(mutable q, ns_idx)
    audit_append(
        mutable q,
        audit.AuditEventKind.enqueued,
        q.last_seen_clock_nanos,
        id,
        0,
        ns,
    )
    return id
}







function bump_ns_enqueued(q: mutable JobQueue, ns_idx: usize) -> () {
    let ns: namespace.NamespaceState = Vec_NamespaceState.at(q.namespaces, ns_idx)
    Vec_NamespaceState.set_at(
        mutable q.namespaces,
        ns_idx,
        namespace.NamespaceState {
            name: ns.name,
            active_capacity: ns.active_capacity,
            dead_letter_capacity: ns.dead_letter_capacity,
            enqueued_total: ns.enqueued_total + 1,
            acquired_total: ns.acquired_total,
            completed_total: ns.completed_total,
            failed_total: ns.failed_total,
            lease_expired_total: ns.lease_expired_total,
            dead_lettered_total: ns.dead_lettered_total,
            retry_scheduled_total: ns.retry_scheduled_total,
            cancelled_total: ns.cancelled_total,
            promoted_total: ns.promoted_total,
        },
    )
}

