public function s13(allocator: Allocator) -> ()
    with {allocator, err: assert.AssertError, err: alloc.AllocError, err: queue_error.QueueError}
{
    var q: queue.JobQueue = queue.new(test_support.default_cfg(), 1, allocator)?
    let id: u64 = queue.enqueue(mutable q, "x", allocator)?
    let clk: clock.LogicalClock = clock.new()
    let _ = queue.acquire(mutable q, 1, 1_000_000_000, clk, allocator)?
    queue.fail(mutable q, 1, id, "transient", clk, allocator)?
    let immediate = queue.acquire(mutable q, 2, 1_000_000_000, clk, allocator)?
    assert.assert_true(
        match immediate {
            case .none => true
            case .some(_) => false
        },
        "s13: failed job should not be immediately available",
    )?
}



public function s14(allocator: Allocator) -> ()
    with {allocator, err: assert.AssertError, err: alloc.AllocError, err: queue_error.QueueError}
{
    var q: queue.JobQueue = queue.new(test_support.default_cfg(), 1, allocator)?
    let id: u64 = queue.enqueue(mutable q, "x", allocator)?
    var clk: clock.LogicalClock = clock.new()
    let _ = queue.acquire(mutable q, 1, 1_000_000_000, clk, allocator)?
    queue.fail(mutable q, 1, id, "transient", clk, allocator)?
    clock.advance(mutable clk, 1_000_000_000)
    let retried = queue.acquire(mutable q, 2, 1_000_000_000, clk, allocator)?
    return match retried {
        case .none => assert.assert_true(false, "s14: should have re-acquired after backoff")?
        case .some(let a) => {
            assert.assert_eq_u64(a.job_id, id, "s14: re-acquired wrong id")?
            assert.assert_eq_u32(a.attempt, 2, "s14: re-acquire attempt should be 2")?
        }
    }
}



public function s15(allocator: Allocator) -> ()
    with {allocator, err: assert.AssertError, err: alloc.AllocError, err: queue_error.QueueError}
{
    var q: queue.JobQueue = queue.new(test_support.default_cfg(), 1, allocator)?
    let id: u64 = queue.enqueue(mutable q, "x", allocator)?
    var clk: clock.LogicalClock = clock.new()
    let limit: usize = 3
    var i: usize = 0
    loop
        decreases limit - i
    {
        if i >= limit { break }
        let _ = queue.acquire(mutable q, 1, 1_000_000_000, clk, allocator)?
        queue.fail(mutable q, 1, id, "transient", clk, allocator)?
        clock.advance(mutable clk, 60_000_000_000)
        i = i + 1
    }
    assert.assert_eq_usize(queue.dead_letter_len(q), 1, "s15: dead-letter should hold the job")?
    assert.assert_eq_usize(queue.active_len(q), 0, "s15: active should be empty")?
    let post = queue.acquire(mutable q, 2, 1_000_000_000, clk, allocator)?
    assert.assert_true(
        match post {
            case .none => true
            case .some(_) => false
        },
        "s15: dead-lettered job must not re-acquire",
    )?
}



public function s16(allocator: Allocator) -> ()
    with {allocator, err: assert.AssertError, err: alloc.AllocError, err: queue_error.QueueError}
{
    var q: queue.JobQueue = queue.new(test_support.default_cfg(), 1, allocator)?
    let id: u64 = queue.enqueue(mutable q, "x", allocator)?
    var clk: clock.LogicalClock = clock.new()
    let _ = queue.acquire(mutable q, 1, 1_000_000, clk, allocator)?
    clock.advance(mutable clk, 2_000_000)
    let retried = queue.acquire(mutable q, 2, 1_000_000_000, clk, allocator)?
    return match retried {
        case .none => assert.assert_true(false, "s16: should re-acquire after lease expiry")?
        case .some(let a) => {
            assert.assert_eq_u64(a.job_id, id, "s16: re-acquired wrong id")?
            assert.assert_eq_u32(a.attempt, 1, "s16: lease expiry must not increment attempt")?
        }
    }
}









public function s17(allocator: Allocator) -> ()
    with {allocator, err: assert.AssertError, err: alloc.AllocError, err: queue_error.QueueError}
{
    var q: queue.JobQueue = queue.new(test_support.jittered_cfg(250_000), 17, allocator)?
    let id: u64 = queue.enqueue(mutable q, "x", allocator)?
    var clk: clock.LogicalClock = clock.new()

    let _ = queue.acquire(mutable q, 1, 1_000_000_000, clk, allocator)?
    queue.fail(mutable q, 1, id, "r1", clk, allocator)?
    
    
    
    clock.advance(mutable clk, 125_000_000)
    let after_first = queue.acquire(mutable q, 2, 1_000_000_000, clk, allocator)?
    return match after_first {
        case .none => assert.assert_true(false, "s17: first retry should be available")?
        case .some(let a1) => {
            assert.assert_eq_u32(a1.attempt, 2, "s17: first retry attempt count")?
            queue.fail(mutable q, 2, id, "r2", clk, allocator)?
            clock.advance(mutable clk, 250_000_000)
            let after_second = queue.acquire(mutable q, 3, 1_000_000_000, clk, allocator)?
            return match after_second {
                case .none => assert.assert_true(false, "s17: second retry should be available")?
                case .some(let a2) => assert.assert_eq_u32(a2.attempt, 3, "s17: second retry attempt count")?
            }
        }
    }
}
