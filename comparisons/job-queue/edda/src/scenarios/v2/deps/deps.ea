






import std.mem.alloc
import local.assert.assert
import local.clock.clock
import local.queue.queue.queue
import local.queue.snapshot.snapshot
import local.queue.error as queue_error
import local.test.support as test_support



public function s100(allocator: Allocator) -> ()
    with {allocator, err: assert.AssertError, err: alloc.AllocError, err: queue_error.QueueError}
{
    var q: queue.JobQueue = queue.new(test_support.default_cfg(), 1, allocator)?
    let no_caps: [String] = test_support.empty_str(allocator)?
    let no_deps: [u64] = test_support.empty_u64(allocator)?
    let parent_id: u64 = queue.enqueue_full2(
        mutable q, "parent", 5, 0, "default", no_deps, no_caps, allocator,
    )?
    let deps: [u64] = test_support.one_u64(parent_id, allocator)?
    let _child_id: u64 = queue.enqueue_full2(
        mutable q, "child", 5, 0, "default", deps, no_caps, allocator,
    )?
    let clk: clock.LogicalClock = clock.new()
    let outcome = queue.acquire(mutable q, 1, 1_000_000_000, clk, allocator)?
    return match outcome {
        case .none => assert.assert_true(false, "s100: parent must be acquirable")?
        case .some(let a) => assert.assert_eq_u64(a.job_id, parent_id, "s100: acquired parent")?
    }
}


public function s101(allocator: Allocator) -> ()
    with {allocator, err: assert.AssertError, err: alloc.AllocError, err: queue_error.QueueError}
{
    var q: queue.JobQueue = queue.new(test_support.default_cfg(), 1, allocator)?
    let no_caps: [String] = test_support.empty_str(allocator)?
    let no_deps: [u64] = test_support.empty_u64(allocator)?
    let parent_id: u64 = queue.enqueue_full2(
        mutable q, "p", 5, 0, "default", no_deps, no_caps, allocator,
    )?
    let deps: [u64] = test_support.one_u64(parent_id, allocator)?
    let child_id: u64 = queue.enqueue_full2(
        mutable q, "c", 5, 0, "default", deps, no_caps, allocator,
    )?
    let clk: clock.LogicalClock = clock.new()
    let _ = queue.acquire(mutable q, 1, 1_000_000_000, clk, allocator)?
    queue.complete(mutable q, 1, parent_id)?
    let outcome = queue.acquire(mutable q, 1, 1_000_000_000, clk, allocator)?
    return match outcome {
        case .none => assert.assert_true(false, "s101: child must be acquirable after parent complete")?
        case .some(let a) => assert.assert_eq_u64(a.job_id, child_id, "s101: acquired child")?
    }
}



public function s102(allocator: Allocator) -> ()
    with {allocator, err: assert.AssertError, err: alloc.AllocError}
{
    var q: queue.JobQueue = queue.new(test_support.default_cfg(), 1, allocator)?
    let no_caps: [String] = test_support.empty_str(allocator)?
    let bad_deps: [u64] = test_support.one_u64(1, allocator)?
    var raised: bool = false
    handle err: queue_error.QueueError -> { raised = true } {
        let _ = queue.enqueue_full2(
            mutable q, "self-cycle", 5, 0, "default", bad_deps, no_caps, allocator,
        )?
    }
    assert.assert_true(raised, "s102: self-cycle must raise invalid_dependency")?
}



public function s103(allocator: Allocator) -> ()
    with {allocator, err: assert.AssertError, err: alloc.AllocError}
{
    var q: queue.JobQueue = queue.new(test_support.default_cfg(), 1, allocator)?
    let no_caps: [String] = test_support.empty_str(allocator)?
    let bogus: [u64] = test_support.one_u64(2, allocator)?
    var raised: bool = false
    handle err: queue_error.QueueError -> { raised = true } {
        let _ = queue.enqueue_full2(
            mutable q, "a", 5, 0, "default", bogus, no_caps, allocator,
        )?
    }
    assert.assert_true(raised, "s103: dep on non-existent id must raise invalid_dependency")?
}


