function run_s01(out: Stdout, allocator: Allocator) -> () with {out, allocator} {
    handle err: assert.AssertError -> { out.print_line("FAIL s01") } {
        handle err: alloc.AllocError -> { out.print_line("FAIL s01 (alloc)") } {
            scenarios_part1.s01(allocator)?
            out.print_line("PASS s01")
        }
    }
}

