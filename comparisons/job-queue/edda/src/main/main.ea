function dispatch_one(
    out: Stdout,
    allocator: Allocator,
    runner: function(Stdout, Allocator) -> () with {out, allocator},
) -> () with {out, allocator}
{
    runner(out, allocator)
}



public function main(out: Stdout, allocator: Allocator) -> ()
